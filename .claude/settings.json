{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(dotnet restore*)",
      "Bash(dotnet build*)",
      "Bash(dotnet run*)",
      "Bash(dotnet publish*)",
      "Bash(dotnet test*)",
      "Bash(dotnet clean*)",
      "Bash(dotnet watch*)",
      "Bash(npm install*)",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(npm ls*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(taskkill*)",
      "Bash(tasklist*)",
      "PowerShell(Stop-Process*)",
      "PowerShell(Get-Process*)",
      "PowerShell(Start-Process*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "Write-Output '{\"systemMessage\": \"Session ending — if architecture, decisions, or phase status changed this session, update CLAUDE.md (Status + Pickup Priorities + What\\u0027s Built) and commit it.\"}'",
            "statusMessage": "Reminding to update CLAUDE.md..."
          }
        ]
      }
    ]
  }
}
