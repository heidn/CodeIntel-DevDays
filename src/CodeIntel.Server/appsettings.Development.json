{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.SignalR": "Debug"
    }
  },
  "Llm": {
    "ContextSize": 16384,
    "GpuLayerCount": 20,
    "MaxResponseTokens": 2048,
    "Threads": 8
  },
  "Analysis": {
    "MaxContextTokens": 12000
  },
  "Lsp": {
    "Enabled": false
  }
}
